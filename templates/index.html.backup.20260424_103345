function showExportModal() {
  // Calculate size info
  var totalBytes = 0;
  var imgCount   = 0;
  var storageKeys = [];
  for (var i = 0; i < localStorage.length; i++) {
    var k = localStorage.key(i);
    if (k && k.startsWith('bodhi_')) {
      var v = localStorage.getItem(k) || '';
      totalBytes += k.length + v.length;
      storageKeys.push(k);
      if (k.startsWith('bodhi_img_')) imgCount++;
    }
  }
  var htmlSize = document.documentElement.outerHTML.length;
  var totalKB  = Math.round((htmlSize + totalBytes) / 1024);

  var infoBox = document.getElementById('export-info-box');
  if (imgCount === 0) {
    infoBox.innerHTML = '⚠️ <strong>Belum ada gambar yang diupload.</strong> File yang diexport hanya berisi konten teks. Upload logo dan foto terlebih dahulu untuk hasil terbaik.';
    infoBox.style.background = '#fff8e0';
    infoBox.style.borderColor = '#f0d080';
  } else {
    infoBox.innerHTML = '✅ <strong>' + imgCount + ' gambar</strong> siap disertakan &nbsp;·&nbsp; Estimasi ukuran file: <strong>~' + totalKB + ' KB</strong>';
    infoBox.style.background = '';
    infoBox.style.borderColor = '';
  }
  openModal('modal-export');
}

function doExport() {
  var btn = document.getElementById('export-dl-btn');
  btn.textContent = '⏳ Menyiapkan...';
  btn.disabled = true;

  setTimeout(function() {
    try {
      // 1. Collect ALL bodhi_ localStorage entries
      var allData = {};
      for (var i = 0; i < localStorage.length; i++) {
        var k = localStorage.key(i);
        if (k && k.startsWith('bodhi_')) {
          allData[k] = localStorage.getItem(k);
        }
      }

      // 2. Temporarily strip admin/edit classes from body so the
      //    exported HTML is clean (not stuck in admin mode on refresh)
      var body = document.body;
      var hadAdmin = body.classList.contains('admin-on');
      var hadEdit  = body.classList.contains('edit-on');
      body.classList.remove('admin-on', 'edit-on');

      // FAB: reset text + title
      var fab = document.getElementById('admin-fab');
      var fabText  = fab ? fab.textContent   : '⚙';
      var fabTitle = fab ? (fab.getAttribute('title')||'Admin Panel') : 'Admin Panel';
      if (fab) { fab.textContent = '⚙'; fab.setAttribute('title','Admin Panel'); }

      // Edit button
      var editBtn = document.getElementById('edit-btn');
      var editBtnText = editBtn ? editBtn.textContent : '✏️ Edit Teks';
      if (editBtn) { editBtn.textContent = '✏️ Edit Teks'; editBtn.style.color = ''; }

      // Close any open modal overlays (they use .open class)
      document.querySelectorAll('.modal-ov').forEach(function(m){
        m.classList.remove('open');
      });

      // 3. Remove any contenteditable attributes
      document.querySelectorAll('[contenteditable]').forEach(function(el){
        el.removeAttribute('contenteditable');
      });

      // 4. Capture clean HTML
      var html = '<!DOCTYPE html>\n' + document.documentElement.outerHTML;

      // 5. Restore admin state in live DOM
      if (hadAdmin) body.classList.add('admin-on');
      if (hadEdit)  body.classList.add('edit-on');
      if (fab) { fab.textContent = fabText; fab.setAttribute('title', fabTitle); }
      if (editBtn && hadEdit) { editBtn.textContent = '✓ Edit Aktif'; editBtn.style.color = 'var(--acc)'; }
      // Re-show export modal in live DOM (user still sees it)
      var expModal = document.getElementById('modal-export');
      if (expModal) expModal.classList.add('open');

      // 6. Deep-clean the HTML string
      html = html.replace(/(<body[^>]*)\badmin-on\b/g, '$1');
      html = html.replace(/(<body[^>]*)\bedit-on\b/g,  '$1');
      html = html.replace(/class="\s+"/g, 'class=""');
      // Fix FAB title in string
      html = html.replace(/(id="admin-fab"[^>]*)title="[^"]*"/g, '$1title="Admin Panel"');
      // *** THE KEY FIX: strip .open class from ALL modal-ov elements ***
      html = html.replace(/(class="modal-ov)\s+open"/g, '$1"');
      html = html.replace(/(class="modal-ov)/g, 'class="modal-ov');
      // Also strip any leftover inline display on modals
      html = html.replace(/(id="modal-[^"]*"[^>]*)style="display:[^"]*"/g, '$1');

      // 7. Build pre-load script that restores all data into localStorage
      var preload = [
        '<script id="bodhi-preload">',
        '(function(){',
        '  var _d=' + JSON.stringify(allData) + ';',
        '  Object.keys(_d).forEach(function(k){',
        '    try{localStorage.setItem(k,_d[k]);}catch(e){}',
        '  });',
        '})();',
        '<\/script>'
      ].join('\n');

      // 8. Inject preload right after <head>
      html = html.replace('<head>', '<head>\n' + preload);

      // 9. Download
      var blob = new Blob([html], { type: 'text/html;charset=utf-8;' });
      var url  = URL.createObjectURL(blob);
      var a    = document.createElement('a');
      a.href     = url;
      a.download = 'bodhi-website.html';
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      setTimeout(function(){ URL.revokeObjectURL(url); }, 3000);

      btn.textContent = '✅ File Terdownload!';
      btn.style.background = '#4B7B58';
      setTimeout(function(){
        btn.textContent = '⬇ Download File HTML';
        btn.style.background = '';
        btn.disabled = false;
        closeModal('modal-export');
        showToast('✅ bodhi-website.html siap diupload ke hosting!');
      }, 2000);

    } catch(err) {
      btn.textContent = '⬇ Download File HTML';
      btn.disabled = false;
      alert('Gagal export: ' + err.message + '\n\nCoba di browser lain (Chrome/Edge).');
    }
  }, 200);
}

