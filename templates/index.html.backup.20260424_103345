/* Rich Text Editor toolbar */
var _rteBar = null;
var _rteSavedRange = null;

// Save current text selection (called on mouseup in contenteditable)
function rteSaveSelection() {
  var sel = window.getSelection();
  if (sel && sel.rangeCount > 0 && !sel.isCollapsed) {
    _rteSavedRange = sel.getRangeAt(0).cloneRange();
  }
}

// Restore saved selection before applying commands
function rteRestoreSelection() {
  if (!_rteSavedRange) return false;
  var sel = window.getSelection();
  sel.removeAllRanges();
  sel.addRange(_rteSavedRange);
  return true;
}

// Apply execCommand with selection restore
function rteDo(cmd) {
  rteRestoreSelection();
  document.execCommand(cmd);
}

// Set text color
function rteSetColor(c) {
  rteRestoreSelection();
  document.execCommand('foreColor', false, c);
}

// Set specific font size (px)
function rteSetSize(px) {
  if (!px) return;
  rteRestoreSelection();
  var sel = window.getSelection();
  if (!sel || sel.isCollapsed) return;
  var range = sel.getRangeAt(0);
  var span = document.createElement('span');
  span.style.fontSize = px + 'px';
  try { range.surroundContents(span); } catch(e) {
    // Fallback: wrap with execCommand fontSize (limited to 1-7)
    document.execCommand('fontSize', false, '3');
    document.querySelectorAll('font[size="3"]').forEach(function(f){
      f.removeAttribute('size');
      f.style.fontSize = px + 'px';
    });
  }
}

// Accent italic style (em with brand color)
function rteAccentStyle() {
  rteRestoreSelection();
  var sel = window.getSelection();
  if (!sel || sel.isCollapsed) return;
  var range = sel.getRangeAt(0);
  var em = document.createElement('em');
  em.style.color = 'var(--acc)'; em.style.fontStyle = 'italic'; em.style.fontWeight = '300';
  try { range.surroundContents(em); } catch(e) { document.execCommand('italic'); }
}

// Legacy aliases (kept for backward compat)
function rteCmd(cmd) { rteDo(cmd); }
function rteColor(c) { rteSetColor(c); }
function rteFontSize(factor) {
  rteRestoreSelection();
  var sel = window.getSelection();
  if (!sel || !sel.rangeCount) return;
  var range = sel.getRangeAt(0);
  var span = document.createElement('span');
  var current = parseFloat(window.getComputedStyle(range.commonAncestorContainer.parentElement).fontSize) || 16;
  span.style.fontSize = Math.round(current * factor) + 'px';
  try { range.surroundContents(span); } catch(e) {}
}
function rteItalicStyle() { rteAccentStyle(); }

function _showRteBar(e) {
  var tb = document.getElementById('rte-toolbar');
  setTimeout(function() {
    var sel = window.getSelection();
    if (!sel || sel.isCollapsed || !sel.toString().trim()) { tb.classList.remove('show'); return; }
    rteSaveSelection(); // Save selection when toolbar appears
    var r = sel.getRangeAt(0).getBoundingClientRect();
    var tx = r.left + window.scrollX + (r.width/2) - 200;
    var ty = r.top + window.scrollY - 58;
    tx = Math.max(8, Math.min(tx, window.innerWidth - 420));
    ty = ty < 60 ? r.bottom + window.scrollY + 8 : ty;
    tb.style.left = tx + 'px';
    tb.style.top  = ty + 'px';
    tb.classList.add('show');
  }, 10);
}
function _hideRteBar(e) {
  if (e && e.relatedTarget && document.getElementById('rte-toolbar').contains(e.relatedTarget)) return;
  setTimeout(function() {
    var sel = window.getSelection();
    if (!sel || sel.isCollapsed) document.getElementById('rte-toolbar').classList.remove('show');
  }, 150);
}

