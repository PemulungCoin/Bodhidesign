<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BODHI Creative + Design — Sekolah Desain Profesional Medan</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400;1,600&amp;family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&amp;display=swap" rel="stylesheet">
<style>
:root{
  --bg:#FFFDF8;--bg2:#F5EEE5;--bgcard:#FFFFFF;--bgwarm:#FDF6EE;
  --text:#1E1810;--textsoft:#4A3F35;--muted:#9A8E82;
  --acc:#C85B2A;--acclt:#F7E8DF;--accdim:#A04520;
  --green:#4B7B58;--greenlt:#E2F0E7;
  --bdr:#E5DDD3;--bdrdk:#CFC3B6;--shd:rgba(30,20,10,.07);--shdlg:rgba(30,20,10,.13);
  --r:14px;--rsm:8px;--rpill:100px;--tr:.3s cubic-bezier(.4,0,.2,1);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:auto}
body{font-family:'Plus Jakarta Sans',sans-serif;background:var(--bg);color:var(--text);line-height:1.6;overflow-x:hidden}
h1,h2,h3,h4{font-family:'Cormorant Garamond',Georgia,serif;font-weight:600;line-height:1.15}
a{color:inherit;text-decoration:none;cursor:pointer}
img{max-width:100%;display:block}
.container{max-width:1160px;margin:0 auto;padding:0 28px}

/* ── NAV ── */
nav{position:fixed;top:0;left:0;right:0;z-index:200;background:rgba(255,253,248,.94);backdrop-filter:blur(18px);border-bottom:1px solid var(--bdr);transition:var(--tr)}
.nav-inner{max-width:1160px;margin:0 auto;padding:0 28px;height:96px;display:flex;align-items:center;justify-content:space-between;gap:16px}

/* LOGO VERTICAL */
.nav-logo{display:flex;flex-direction:column;align-items:center;gap:5px;cursor:pointer;flex-shrink:0}
.nav-logo-wrap{position:relative;width:68px;height:68px;border-radius:14px;overflow:hidden;background:linear-gradient(135deg,var(--accdim),var(--acc));display:flex;align-items:center;justify-content:center;flex-shrink:0;box-shadow:0 4px 16px rgba(200,91,42,.25)}
.nav-logo-def{font-family:'Cormorant Garamond',serif;font-size:36px;font-weight:700;color:#fff;line-height:1;position:relative;z-index:1}
.nav-logo-img-el{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:none;border-radius:14px}
.nav-logo-img-el.show{display:block}
.nav-logo-wrap:has(.nav-logo-img-el.show) .nav-logo-def{display:none}
.nav-brand{font-family:'Cormorant Garamond',serif;font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--text);text-align:center;line-height:1.35;white-space:nowrap}
.nav-brand em{color:var(--acc);font-style:normal}
/* logo upload overlay */
.logo-upload-ov{display:none;position:absolute;inset:0;background:rgba(200,91,42,.7);align-items:center;justify-content:center;cursor:pointer;border-radius:14px;z-index:10;font-size:20px;flex-direction:column;gap:3px}
.logo-upload-ov span{color:#fff;font-size:10px;font-weight:700;letter-spacing:.3px}
body.admin-on .nav-logo-wrap:hover .logo-upload-ov{display:flex}

.nav-links{display:flex;gap:22px;list-style:none}
.nav-links a{font-size:13px;font-weight:500;color:var(--muted);transition:color .2s;white-space:nowrap;cursor:pointer}
.nav-links a:hover{color:var(--acc)}
.nav-cta{background:var(--acc);color:#fff;font-size:13px;font-weight:700;padding:10px 22px;border-radius:var(--rpill);white-space:nowrap;transition:var(--tr);border:none;cursor:pointer;font-family:inherit;box-shadow:0 2px 12px rgba(200,91,42,.25)}
.nav-cta:hover{background:var(--accdim);transform:translateY(-1px)}

/* ── ADMIN BAR ── */
#admin-bar{position:fixed;top:0;left:0;right:0;z-index:1000;background:#fff8f5;border-bottom:2px solid var(--acc);padding:8px 20px;display:none;align-items:center;justify-content:space-between;gap:12px;font-size:13px;flex-wrap:wrap}
body.admin-on #admin-bar{display:flex}
body.admin-on nav{top:46px}
.abar-left{font-weight:700;color:var(--acc);font-size:13px;display:flex;align-items:center;gap:6px}
.abar-right{display:flex;gap:6px;align-items:center;flex-wrap:wrap}
.abtn{padding:6px 12px;border-radius:6px;border:none;cursor:pointer;font-size:12px;font-weight:600;font-family:inherit;transition:var(--tr)}
.abtn-ol{background:#fff;border:1px solid var(--bdr);color:var(--textsoft)}.abtn-ol:hover{border-color:var(--acc);color:var(--acc)}
.abtn-acc{background:var(--acc);color:#fff}.abtn-acc:hover{background:var(--accdim)}
.abtn-gray{background:var(--bg2);color:var(--muted);border:1px solid var(--bdr)}.abtn-gray:hover{color:var(--text)}
.abtn-green{background:#e8f5ee;color:var(--green);border:1px solid #b8dfc8}.abtn-green:hover{background:#d0edd8}
.abtn-blue{background:#e8f0ff;color:#3060c0;border:1px solid #b8c8f0}.abtn-blue:hover{background:#d0e0ff}
.abtn-purple{background:#f0e8ff;color:#6040c0;border:1px solid #d0b8f0}.abtn-purple:hover{background:#e4d8ff}
.abtn-orange{background:#fff3e0;color:#b85000;border:1px solid #f0c880;font-weight:700}.abtn-orange:hover{background:#ffe0b0}

/* Export modal */
.export-step{display:flex;align-items:flex-start;gap:14px;padding:14px 16px;border-radius:12px;background:var(--bgwarm);border:1px solid var(--bdr);margin-bottom:10px}
.export-step-num{width:28px;height:28px;border-radius:50%;background:var(--acc);color:#fff;font-size:12px;font-weight:800;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.export-step-text{font-size:14px;color:var(--textsoft);line-height:1.5}
.export-step-text strong{color:var(--text)}
.export-info-box{background:var(--acclt);border:1px solid rgba(200,91,42,.2);border-radius:12px;padding:16px 20px;margin-bottom:16px;font-size:13px;color:var(--textsoft);line-height:1.7}
.export-size-bar{height:8px;background:var(--bdr);border-radius:100px;margin-top:8px;overflow:hidden}
.export-size-fill{height:100%;background:linear-gradient(90deg,var(--acc),var(--accdim));border-radius:100px;width:0;transition:width .8s ease}

#admin-fab{position:fixed;bottom:28px;right:28px;z-index:999;width:50px;height:50px;border-radius:50%;background:var(--bgcard);border:1.5px solid var(--bdr);color:var(--muted);font-size:20px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:var(--tr);box-shadow:0 4px 20px var(--shdlg)}
#admin-fab:hover{border-color:var(--acc);color:var(--acc);transform:scale(1.08)}
body.admin-on #admin-fab{background:var(--acc);color:#fff;border-color:var(--acc)}

/* ── SECTION ADMIN OVERLAY ── */
.sw{position:relative}
body.admin-on .sw::after{content:'';position:absolute;inset:0;border:2px dashed rgba(200,91,42,.15);pointer-events:none;z-index:10;border-radius:2px}
.sc{display:none;position:absolute;top:10px;right:14px;z-index:50;gap:6px;align-items:center;background:rgba(255,253,248,.97);border:1px solid var(--bdrdk);border-radius:var(--rsm);padding:6px 10px;box-shadow:0 4px 16px var(--shdlg)}
body.admin-on .sc{display:flex}
.sc-lbl{font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;padding-right:8px;border-right:1px solid var(--bdr);margin-right:4px}
.scbtn{border:none;cursor:pointer;font-size:11px;font-weight:600;padding:5px 10px;border-radius:5px;font-family:inherit;transition:var(--tr)}
.scbtn-h{background:#F5EDDA;color:#9A7030}.scbtn-h:hover{background:#eddcb0}
.scbtn-d{background:#FDEAEA;color:#C03030}.scbtn-d:hover{background:#f8d0d0}
.sw.sec-hidden>*:not(.sc){opacity:.18;pointer-events:none;filter:blur(2px)}
.sw.sec-deleted{display:none!important}
.hbadge{display:none;position:absolute;top:10px;left:14px;background:#F5EDDA;border:1px solid #d4b860;color:#9A7030;font-size:11px;font-weight:700;padding:3px 10px;border-radius:100px;z-index:20}
body.admin-on .sw.sec-hidden .hbadge{display:block}

/* ── IMAGE UPLOAD ── */
.img-wrap{position:relative;overflow:hidden}
.img-upload-ov{display:none;position:absolute;inset:0;background:rgba(200,91,42,.65);align-items:center;justify-content:center;flex-direction:column;gap:4px;cursor:pointer;z-index:5;transition:.2s}
body.admin-on .img-wrap:hover .img-upload-ov{display:flex}
.img-upload-ov .cam{font-size:24px}
.img-upload-ov span{color:#fff;font-size:10px;font-weight:700;letter-spacing:.5px;text-transform:uppercase}
#img-file-input{display:none}

/* ── EDIT MODE ── */
body.edit-on [contenteditable="true"]{outline:1.5px dashed rgba(200,91,42,.4);border-radius:3px;cursor:text}
body.edit-on [contenteditable="true"]:focus{outline:2px solid var(--acc);background:rgba(200,91,42,.04)}
/* Rich-text floating toolbar */
#rte-toolbar{position:fixed;z-index:9999;background:#1e1810;border-radius:10px;padding:6px 8px;display:none;gap:4px;align-items:center;box-shadow:0 8px 32px rgba(0,0,0,.35);flex-wrap:wrap;max-width:340px}
#rte-toolbar.show{display:flex}
.rte-btn{background:transparent;border:none;color:#fff;cursor:pointer;font-size:13px;padding:5px 8px;border-radius:6px;font-family:inherit;transition:.15s;white-space:nowrap}
.rte-btn:hover{background:rgba(255,255,255,.15)}
.rte-btn.active{background:var(--acc)}
.rte-sep{width:1px;height:18px;background:rgba(255,255,255,.2);margin:0 2px}
.rte-color-row{display:flex;gap:3px;padding:0 4px}
.rte-color{width:18px;height:18px;border-radius:50%;cursor:pointer;border:2px solid transparent;transition:.15s}
.rte-color:hover,.rte-color.active{border-color:#fff;transform:scale(1.15)}

/* ── MODALS ── */
.modal-ov{display:none;position:fixed;inset:0;background:rgba(30,24,16,.55);z-index:2000;align-items:center;justify-content:center;backdrop-filter:blur(6px)}
.modal-ov.open{display:flex}
.mbox{background:var(--bgcard);border:1px solid var(--bdrdk);border-radius:20px;padding:36px;width:460px;max-width:92vw;box-shadow:0 20px 60px var(--shdlg)}
.mbox-lg{width:780px;max-width:96vw;max-height:88vh;display:flex;flex-direction:column}
.mbox-xl{width:860px;max-width:96vw;max-height:92vh;display:flex;flex-direction:column}
.mtitle{font-size:24px;margin-bottom:6px}
.msub{font-size:13px;color:var(--muted);margin-bottom:22px}
.minput{width:100%;padding:12px 15px;background:var(--bgwarm);border:1.5px solid var(--bdr);border-radius:var(--rsm);color:var(--text);font-family:inherit;font-size:14px;outline:none;transition:border-color .2s;margin-bottom:10px}
.minput:focus{border-color:var(--acc)}
.merr{font-size:13px;color:#C03030;min-height:20px;margin-bottom:10px}
.mbtns{display:flex;gap:10px}
.mbtn{flex:1;padding:12px;border:none;border-radius:var(--rsm);font-family:inherit;font-size:14px;font-weight:700;cursor:pointer;transition:var(--tr)}
.mbtn-cancel{background:var(--bg2);color:var(--muted)}.mbtn-cancel:hover{color:var(--text)}
.mbtn-ok{background:var(--acc);color:#fff}.mbtn-ok:hover{background:var(--accdim)}
.mscroll{overflow-y:auto;flex:1;margin-top:16px;padding-right:4px}
.mscroll::-webkit-scrollbar{width:4px}.mscroll::-webkit-scrollbar-track{background:var(--bg2)}.mscroll::-webkit-scrollbar-thumb{background:var(--bdrdk);border-radius:4px}

/* Settings grid */
.settings-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:24px}
.sfield{display:flex;flex-direction:column;gap:6px}
.sfield label{font-size:12px;font-weight:700;color:var(--textsoft)}
.sfield input,.sfield select{padding:11px 14px;background:var(--bgwarm);border:1.5px solid var(--bdr);border-radius:var(--rsm);color:var(--text);font-family:inherit;font-size:14px;outline:none;transition:border-color .2s;width:100%}
.sfield input:focus,.sfield select:focus{border-color:var(--acc)}
.sfield .hint{font-size:11px;color:var(--muted);margin-top:2px}
.sfield-full{grid-column:span 2}

/* FAQ Manager */
.faq-mgr-item{background:var(--bgwarm);border:1.5px solid var(--bdr);border-radius:12px;padding:16px;margin-bottom:10px;transition:border-color .2s}
.faq-mgr-item:hover{border-color:var(--acc)}
.faq-mgr-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
.faq-mgr-num{font-size:11px;font-weight:700;color:var(--acc);background:var(--acclt);padding:3px 9px;border-radius:100px}
.faq-mgr-del{background:#FDEAEA;color:#C03030;border:none;padding:5px 10px;border-radius:6px;font-size:11px;font-weight:600;cursor:pointer;font-family:inherit;transition:var(--tr)}
.faq-mgr-del:hover{background:#f8d0d0}
.faq-mgr-label{font-size:12px;font-weight:600;color:var(--textsoft);margin-bottom:4px}
.faq-mgr-input{width:100%;padding:10px 12px;background:var(--bgcard);border:1.5px solid var(--bdr);border-radius:var(--rsm);color:var(--text);font-family:inherit;font-size:13px;outline:none;transition:border-color .2s;margin-bottom:8px}
.faq-mgr-input:focus{border-color:var(--acc)}
.faq-mgr-textarea{width:100%;padding:10px 12px;background:var(--bgcard);border:1.5px solid var(--bdr);border-radius:var(--rsm);color:var(--text);font-family:inherit;font-size:13px;outline:none;resize:vertical;min-height:80px;transition:border-color .2s;line-height:1.5}
.faq-mgr-textarea:focus{border-color:var(--acc)}

/* Member table */
.mtable{width:100%;border-collapse:collapse;font-size:13px}
.mtable th{background:var(--bg2);padding:10px 14px;text-align:left;font-weight:700;font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);border-bottom:1px solid var(--bdr)}
.mtable td{padding:10px 14px;border-bottom:1px solid var(--bdr);color:var(--textsoft);vertical-align:middle}
.mtable tr:last-child td{border-bottom:none}
.mtable tr:hover td{background:var(--bgwarm)}
.badge-prog{font-size:11px;font-weight:600;padding:3px 9px;border-radius:100px;background:var(--acclt);color:var(--accdim);white-space:nowrap}

/* ── SHARED SECTION STYLES ── */
.section-tag{display:inline-flex;align-items:center;gap:8px;font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--acc);margin-bottom:14px}
.section-tag::before{content:'';width:20px;height:2px;background:var(--acc);border-radius:2px}
.sec-title{font-size:clamp(30px,3vw,44px);line-height:1.15}
.sec-title em{color:var(--acc);font-weight:300}
.fade-up{opacity:0;transform:translateY(28px);transition:opacity .65s ease,transform .65s ease}
.fade-up.vis{opacity:1;transform:translateY(0)}
.fade-up:nth-child(2){transition-delay:.08s}.fade-up:nth-child(3){transition-delay:.16s}
.fade-up:nth-child(4){transition-delay:.24s}.fade-up:nth-child(5){transition-delay:.32s}

/* ── HERO ── */
#hero{padding:180px 0 90px;position:relative;overflow:hidden}
.hero-d1{position:absolute;top:60px;right:-80px;width:500px;height:500px;border-radius:50%;background:radial-gradient(circle,rgba(200,91,42,.07),transparent 70%);pointer-events:none}
.hero-d2{position:absolute;bottom:-100px;left:-100px;width:400px;height:400px;border-radius:50%;background:radial-gradient(circle,rgba(75,123,88,.06),transparent 70%);pointer-events:none}
.hero-grid{display:grid;grid-template-columns:1fr 420px;gap:60px;align-items:center}
.hero-badge{display:inline-flex;align-items:center;gap:8px;border:1.5px solid rgba(200,91,42,.3);background:var(--acclt);color:var(--acc);font-size:11px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;padding:6px 14px;border-radius:100px;margin-bottom:22px}
.hero-badge::before{content:'';width:7px;height:7px;border-radius:50%;background:var(--acc);animation:blink 2s infinite}
@keyframes blink{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.6)}}
.hero-title{font-size:clamp(44px,5vw,72px);font-weight:700;letter-spacing:-1.5px;line-height:1.06;margin-bottom:22px}
.hero-title em{font-style:italic;color:var(--acc);font-weight:300}
.hero-sub{font-size:16px;color:var(--textsoft);line-height:1.75;margin-bottom:36px;max-width:500px}
.hero-pills{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:38px}
.pill{display:flex;align-items:center;gap:7px;font-size:13px;color:var(--textsoft);background:var(--bgcard);border:1px solid var(--bdr);padding:8px 15px;border-radius:100px;box-shadow:0 2px 8px var(--shd)}
.pill-ic{color:var(--acc);font-size:14px}
.hero-ctas{display:flex;gap:14px;align-items:center;flex-wrap:wrap}
.btn-pri{background:var(--acc);color:#fff;font-weight:700;font-size:14px;padding:15px 32px;border-radius:var(--rpill);border:none;cursor:pointer;font-family:inherit;transition:var(--tr);box-shadow:0 4px 16px rgba(200,91,42,.3)}
.btn-pri:hover{background:var(--accdim);transform:translateY(-2px);box-shadow:0 8px 24px rgba(200,91,42,.4)}
.btn-ghost{color:var(--muted);font-size:14px;font-weight:600;display:flex;align-items:center;gap:6px;transition:color .2s;cursor:pointer;border:none;background:none;font-family:inherit}
.btn-ghost:hover{color:var(--acc)}
.hero-visual{position:relative}
.hero-card{border-radius:20px;overflow:hidden;background:linear-gradient(150deg,var(--bg2),#eeddd0);border:1px solid var(--bdrdk);aspect-ratio:4/5;display:flex;align-items:flex-end;padding:28px;position:relative;box-shadow:0 20px 60px var(--shdlg)}
.hero-card-pat{position:absolute;inset:0;background-image:radial-gradient(circle at 30% 20%,rgba(200,91,42,.08),transparent 40%),radial-gradient(circle at 80% 70%,rgba(75,123,88,.06),transparent 40%)}
.hero-card-grid{position:absolute;inset:0;opacity:.3;background-image:linear-gradient(rgba(200,91,42,.07) 1px,transparent 1px),linear-gradient(90deg,rgba(200,91,42,.07) 1px,transparent 1px);background-size:28px 28px}
.hero-card-img{position:absolute;inset:0;background-size:cover;background-position:center;display:none}
.hero-card-icon{position:absolute;top:28px;left:28px;font-size:64px;opacity:.2;transform:rotate(-10deg)}
.hero-card-text{position:relative;z-index:1}
.hero-card-num{font-family:'Cormorant Garamond',serif;font-size:52px;font-weight:700;color:var(--acc);line-height:1}
.hero-card-lbl{font-size:14px;color:var(--textsoft);margin-top:4px}
.hfloat{position:absolute;background:var(--bgcard);border:1px solid var(--bdrdk);border-radius:14px;padding:14px 18px;box-shadow:0 8px 28px var(--shdlg)}
.hf1{top:28px;left:-30px;display:flex;align-items:center;gap:12px}
.hf-ic{width:38px;height:38px;border-radius:10px;background:var(--acclt);display:flex;align-items:center;justify-content:center;font-size:18px}
.hf-lbl{font-size:12px;color:var(--muted);margin-bottom:2px}
.hf-val{font-size:14px;font-weight:700}
.hf2{bottom:120px;right:-24px;text-align:center;min-width:100px}
.hf2-num{font-size:26px;font-weight:800;color:var(--green)}
.hf2-lbl{font-size:11px;color:var(--muted);margin-top:2px}

/* Trust dots */
.hero-trust{margin-top:20px;display:flex;align-items:center;gap:12px;font-size:12px;color:var(--muted)}
.trust-dots{display:flex}
.trust-dot{width:32px;height:32px;border-radius:50%;border:2.5px solid var(--bg);margin-left:-9px;font-size:11px;font-weight:800;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,var(--acclt),#f0d8cc);color:var(--accdim);overflow:hidden;flex-shrink:0;position:relative}
.trust-dot:first-child{margin-left:0}
.trust-dot img{width:100%;height:100%;object-fit:cover;border-radius:50%;display:none}
.trust-dot img.show{display:block}

/* ── MARQUEE ── */
.marquee-sec{border-top:1px solid var(--bdr);border-bottom:1px solid var(--bdr);padding:14px 0;overflow:hidden;background:var(--bg2)}
.mtrack{display:flex;white-space:nowrap;animation:mq 30s linear infinite}
.mitem{display:inline-flex;align-items:center;gap:10px;padding:0 24px;font-size:13px;font-weight:500;color:var(--textsoft);flex-shrink:0}
.mdot{color:var(--acc);font-size:12px}
@keyframes mq{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* ── ABOUT ── */
#about{padding:100px 0;background:var(--bg2)}
.about-grid{display:grid;grid-template-columns:360px 1fr;gap:48px;align-items:start;margin-top:52px}
.about-visual-col{display:flex;flex-direction:column;gap:16px}
.about-card{border-radius:20px;background:linear-gradient(150deg,#f5ede4,#eeddd0);border:1px solid var(--bdrdk);padding:44px 38px;box-shadow:0 12px 40px var(--shdlg);position:relative;overflow:hidden}
.about-card::before{content:'✦';position:absolute;top:-10px;right:20px;font-size:120px;color:rgba(200,91,42,.06);pointer-events:none;font-family:serif}
.about-year{font-family:'Cormorant Garamond',serif;font-size:88px;font-weight:700;color:var(--acc);line-height:1}
.about-year-lbl{font-size:14px;color:var(--textsoft);margin-bottom:28px}
.about-stats{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.astat{background:rgba(255,255,255,.6);border:1px solid rgba(255,255,255,.8);border-radius:12px;padding:16px}
.astat-num{font-family:'Cormorant Garamond',serif;font-size:32px;font-weight:700;color:var(--acc);line-height:1}
.astat-lbl{font-size:12px;color:var(--textsoft);margin-top:4px}
.about-content{display:flex;flex-direction:column;gap:24px}
.about-lead{font-size:17px;color:var(--textsoft);line-height:1.75}
.vm-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.vm-card{background:var(--bgcard);border:1px solid var(--bdr);border-radius:14px;padding:22px;transition:var(--tr)}
.vm-card:hover{border-color:var(--acc);box-shadow:0 4px 20px var(--shd)}
.vm-icon{font-size:24px;margin-bottom:10px}
.vm-title{font-size:20px;margin-bottom:8px}
.vm-text{font-size:13px;color:var(--textsoft);line-height:1.65}
.about-pts{list-style:none;display:flex;flex-direction:column;gap:10px}
.about-pts li{font-size:14px;color:var(--textsoft);display:flex;align-items:flex-start;gap:10px;line-height:1.6}
.about-pts li::before{content:'✦';color:var(--acc);font-size:10px;flex-shrink:0;margin-top:4px}

/* ── FOR WHO ── */
#for-who{padding:100px 0}
.fw-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;margin-top:52px}
.fw-card{background:var(--bgcard);border:1px solid var(--bdr);border-radius:var(--r);padding:30px 26px;transition:var(--tr)}
.fw-card:hover{border-color:var(--acc);box-shadow:0 8px 28px var(--shdlg);transform:translateY(-4px)}
.fw-num{font-family:'Cormorant Garamond',serif;font-size:52px;font-weight:300;-webkit-text-stroke:1.5px var(--acc);color:transparent;line-height:1;margin-bottom:14px}
.fw-card h3{font-size:16px;font-weight:700;margin-bottom:8px;font-family:'Plus Jakarta Sans'}
.fw-card p{font-size:13px;color:var(--muted);line-height:1.65}

/* ── FOUNDER ── */
#founder{padding:100px 0;background:var(--bg2)}
.founder-grid{display:grid;grid-template-columns:340px 1fr;gap:60px;align-items:start;margin-top:52px}
.founder-card{background:var(--bgcard);border:1px solid var(--bdrdk);border-radius:20px;overflow:hidden;box-shadow:0 12px 40px var(--shdlg);position:sticky;top:90px}
.founder-photo-wrap{width:100%;height:280px;position:relative}
.founder-photo-ph{width:100%;height:100%;background:linear-gradient(150deg,var(--bg2),#e8ddd0);display:flex;align-items:center;justify-content:center;font-size:80px}
.founder-photo-ph::after{content:'';position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(255,253,248,.9) 100%)}
.fpgrid{position:absolute;inset:0;opacity:.4;background-image:linear-gradient(rgba(200,91,42,.06) 1px,transparent 1px),linear-gradient(90deg,rgba(200,91,42,.06) 1px,transparent 1px);background-size:24px 24px}
.founder-photo-actual{position:absolute;inset:0;background-size:cover;background-position:center;display:none}
.founder-body{padding:24px}
.founder-role{font-size:12px;font-weight:700;color:var(--acc);text-transform:uppercase;letter-spacing:.8px;margin-bottom:6px}
.founder-name{font-size:26px;margin-bottom:8px}
.founder-tag-line{font-size:13px;color:var(--muted);line-height:1.6;margin-bottom:16px}
.ftags{display:flex;flex-wrap:wrap;gap:6px}
.ftag{font-size:11px;font-weight:600;padding:4px 10px;border-radius:100px;background:var(--acclt);color:var(--accdim);border:1px solid rgba(200,91,42,.2)}
.founder-detail{display:flex;flex-direction:column;gap:28px}
.fd-blk h3{font-size:20px;margin-bottom:12px}
.fd-blk p{font-size:14px;color:var(--textsoft);line-height:1.75}
.fd-timeline{display:flex;flex-direction:column;gap:10px}
.fd-item{display:flex;gap:14px;align-items:flex-start;background:var(--bgcard);border:1px solid var(--bdr);border-radius:12px;padding:14px 16px;transition:var(--tr)}
.fd-item:hover{border-color:var(--acc)}
