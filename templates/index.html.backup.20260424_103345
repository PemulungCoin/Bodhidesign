(function(){
  var _d={"bodhi_secbgs_cfg":"{\"about\":{\"opacity\":67,\"blur\":0,\"hasImg\":true},\"programs\":{\"hasImg\":true}}","bodhi_faq":"[{\"kw\":\"program, tersedia, ada apa, pilihan program\",\"ans\":\"BODHI punya 2 program:\\n\\n🏠 **Profesional Eksklusif** – 50 pertemuan, untuk semua usia yang ingin berkarir sebagai designer interior\\n\\n🎓 **Arsitektur Interior SMU/SMK** – khusus pelajar untuk persiapan portofolio & beasiswa\\n\\nMau tahu lebih detail yang mana?\"},{\"kw\":\"berapa lama, durasi, lama belajar, pertemuan\",\"ans\":\"Program Profesional Eksklusif terdiri dari **50 pertemuan** intensif. Dengan jadwal 2-3x seminggu, bisa selesai dalam beberapa bulan! 📅\"},{\"kw\":\"online, offline, kelas online, daring, virtual\",\"ans\":\"Ya, tersedia **Online dan Offline** keduanya! 💻 Kamu bisa pilih sesuai kenyamanan, atau bahkan kombinasikan keduanya.\"},{\"kw\":\"pengalaman, pemula, nol, belum bisa, baru mulai\",\"ans\":\"Tidak perlu pengalaman sama sekali! 🙌 Kurikulum dirancang dari **nol** dan mudah dipahami di segala usia. Yang penting semangat belajar!\"},{\"kw\":\"biaya, harga, bayar, fee, cost, berapa bayar\",\"ans\":\"Untuk info biaya dan paket terbaik, langsung konsultasi dengan tim kami ya! Tersedia pilihan pembayaran yang fleksibel. Klik tombol di bawah 👇\"},{\"kw\":\"jadwal, jam, hari belajar, waktu belajar, sesi\",\"ans\":\"Jadwal belajar:\\n📅 **Senin – Sabtu** (2-3x/minggu)\\n⏰ **Sesi 1:** 15.00 – 16.30 WIB\\n⏰ **Sesi 2:** 18.00 – 19.30 WIB\"},{\"kw\":\"daftar, cara daftar, mendaftar, registrasi, bergabung\",\"ans\":\"Cara daftar sangat mudah! 🎉 Isi form di halaman ini atau langsung chat via WhatsApp. Tim kami akan bantu semuanya!\"},{\"kw\":\"software, aplikasi, autocad, sketchup, enscape, 3d, rendering\",\"ans\":\"Software yang dipelajari:\\n🖥️ **AutoCAD** – gambar teknik 2D\\n🏠 **SketchUp + 3ds Max** – modeling 3D\\n✨ **Enscape** – rendering realistis\"},{\"kw\":\"sertifikat, ijazah, bukti, tanda lulus\",\"ans\":\"Ya! Peserta yang lulus mendapat **Sertifikat Penyelesaian** dari BODHI. Cocok untuk portofolio dan CV profesional! 🏆\"},{\"kw\":\"lokasi, dimana, alamat, tempat, jalan\",\"ans\":\"📍 **Jl. Pelita I No.74D**, Kel. Sidorame Timur, Kec. Medan Perjuangan, Kota Medan, Sumatera Utara 20233\\n\\nAda kelas **online** juga jika kamu di luar Medan!\"},{\"kw\":\"mentor, pengajar, siapa yang ngajar, guru, dosen, instruktur\",\"ans\":\"Pengajar utama adalah **Jamry, S.T., M.Psi** 👨‍🏫 — Arsitek sekaligus Magister Psikologi Industri. Berpengalaman sejak 1999 dan mendirikan BODHI sejak 2011.\"},{\"kw\":\"pendampingan, setelah lulus, pasca lulus, garansi, konsultasi proyek\",\"ans\":\"Ya! Ada **Program Pendampingan Proyek Design** setelah lulus — konsultasi design, bantuan pelaksanaan proyek, dan kemitraan kontraktor. Bergaransi! 🤝\"},{\"kw\":\"siswa sma, smk, slta, pelajar, beasiswa, luar negeri, portfolio\",\"ans\":\"Program **Arsitektur Interior SMU/SMK/SLTA** dirancang khusus untuk pelajar yang ingin mempersiapkan portofolio masuk universitas luar negeri dan meraih beasiswa! 🎓\"},{\"kw\":\"mulai, start\",\"ans\":\"jadwal tentativ\"}]","bodhi_cd":"1776822485862","bodhi_img_logo":"data:image/jpeg;base64,","bodhi_typo":"{\"sz-h2\":\"36\",\"sz-h3\":\"25\",\"sz-h4\":\"24\",\"sz-h1\":\"52\",\"sz-p\":\"15\"}","bodhi_img_tw_t1":"data:image/jpeg;base64,","bodhi_img_hero_main":"data:image/jpeg;base64,","bodhi_secbg_about":"data:image/jpeg;base64,","bodhi_img_about_main":"data:image/jpeg;base64,","bodhi_img_founder_photo":"data:image/jpeg;base64,","bodhi_img_ta_t1":"data:image/jpeg;base64,","bodhi_secbg_programs":"data:image/jpeg;base64,","bodhi_texts":"{\"t0\":\"Password default: <code style=\\\"color:var(--acc);font-weight:700\\\">admin123</code>\",\"t1\":\"Belum ada pendaftar.\",\"t2\":\"Jadilah&nbsp;<div><em><font style=\\\"font-size: 64px;\\\">Designer&nbsp;</font></em><i><font style=\\\"font-size: 64px;\\\" color=\\\"#9a8e82\\\">Profesional</font></i><em><font color=\\\"#3060c0\\\"><b></b></font></em><em></em></div>\",\"t3\":\"BODHI Creative + Design hadir sejak 2011 untuk mencetak desainer interior profesional melalui kurikulum praktis, mentor berpengalaman, dan metode belajar yang mudah diterapkan di segala usia.\",\"t4\":\"Wadah pendidikan lahir dari <em>riset nyata</em>\",\"t5\":\"BODHI Creative + Design adalah wadah pendidikan yang lahir dari gagasan kuat, hasil riset nyata tentang kebutuhan tenaga kreatif dan tuntutan dunia design. Kami percaya tenaga ahli yang kreatif bisa dicetak secara singkat — tanpa harus bertahun-tahun lamanya.\",\"t6\":\"Profesi AHLI yang lahir dari KREATIFITAS sejalan dengan Teknologi dan Perubahan.\",\"t7\":\"Mempersiapkan dan menjadikan PROFESI seorang Profesional Designer secara Singkat melalui cara-cara yang tepat, penuh kepastian, bersama tenaga ahli berpengalaman dekade lamanya.\",\"t8\":\"Kursus ini cocok buat <em>siapa saja sih ?</em>\",\"t9\":\"Pemula yang Ingin Berkarir\",\"t10\":\"Belum punya pengalaman? Kurikulum dirancang dari nol agar mudah dipahami dan langsung bisa diterapkan.\",\"t11\":\"Pelajar SMU / SMK / SLTA\",\"t12\":\"Persiapkan portofolio kuat untuk masuk perguruan tinggi terkemuka dalam/luar negeri, bahkan meraih beasiswa.\",\"t13\":\"Mahasiswa Segala Jurusan\",\"t14\":\"Tambah keahlian desain interior sebagai profesi tambahan yang menjanjikan atau jadikan karier utama.\",\"t15\":\"Profesional yang Ganti Karier\",\"t16\":\"Latar belakang bukan desain? Program kami dirancang untuk berbagai latar belakang profesi dan usia.\",\"t17\":\"Pengusaha Bisnis Kreatif\",\"t18\":\"Ingin membangun bisnis konsultan atau kontraktor interior? Kami siapkan strategi, skill, dan pendampingan.\",\"t19\":\"Belajar dari yang <em>telah terbukti</em>\",\"t20\":\"Jamry, S.T., M.Psi\",\"t21\":\"Arsitek, Praktisi Psikologi, Konsultan Perencana &amp; Kontraktor Building sejak 1999. Founder BODHI Creative + Design.\",\"t22\":\"Latar Belakang\",\"t23\":\"Alumni Arsitektur Institut Sains &amp; Teknologi TD. Pardede Medan tahun 1999, dan meraih gelar Magister Psikologi Industri dan Organisasi dengan fokus riset ilmu design terhadap perkembangan perilaku manusia serta pengaruhnya terhadap bisnis.<br><br>Sejak 1999 aktif sebagai Konsultan Perencana dan Kontraktor Building. Mendirikan Intrash-design, karya daur ulang (upcycling) untuk produk design. Saat ini juga Dosen Arsitektur di Institute Modern of Architecture and Technology Medan.\",\"t24\":\"Perjalanan Karier\",\"t25\":\"Lulus Arsitektur IST TD. Pardede — mulai berkarir sebagai Konsultan &amp; Kontraktor Building\",\"t26\":\"Mendirikan BODHI Creative + Design sebagai wadah pendidikan desain informal profesional\",\"t27\":\"Delegate Asia Pacific Space Designers Alliance (APSDA) — Solo, Yogyakarta\",\"t28\":\"Koordinator PSDM Himpunan Designer Interior Indonesia (HDII) Sumatera Utara\",\"t29\":\"Presiden Lions Club Medan Premier, Distrik 307A2\",\"t30\":\"Alumni Faculty Development Institute — Peninsula Jakarta &amp; Regional Lions Leadership Institute — Santika Medan\",\"t31\":\"Cambridge\",\"t32\":\"Pilih program yang <em>sesuai kamu</em>\",\"t33\":\"Profesional Eksklusif <em>(Interior)</em>\",\"t34\":\"Program intensif untuk mencetak designer dan kontraktor interior profesional secara singkat, jelas, dan padat melalui kurikulum sistematis yang dinamis.\",\"t35\":\"Pengetahuan dan pelatihan dasar sumber seluruh konsep bentuk dan model dalam menghasilkan satu bentuk hingga menjadi suatu fungsi. Focus pada teknis yang terarah dan jelas, mudah diterapkan pada pedesignan.\",\"t36\":\"Teknik mengarahkan dalam menerjemahkan tujuan penggambaran secara menarik yang sederhana, mencakup keseluruhan dan menjawab semua kebutuhan yang bersifat realistis.\",\"t37\":\"Langkah/tahapan yang sistematis serta dapat dilaksanakan dengan mudah dan menarik, tanpa harus melalui plagiat atau mengambil karya orang lain.\",\"t38\":\"Produk daur ulang (recycle &amp; upcycle) yang menjadi trend topik di era globalisasi pada industri kreatif design dan memiliki nilai jual tinggi.\",\"t39\":\"Pengetahuan dan ilmu psikologi tentang manusia terhadap sebuah karya, baik sebelum ataupun sesudah dimulainya produksi karya design.\",\"t40\":\"Cara menjual dan memasarkan karya — teknik konseling pertemuan dengan owner, menjawab pertanyaan, dan meyakinkan konsumen.\",\"t41\":\"Setiap peserta harus mampu membangun bisnis dunia design sebagai harapan, baik sebagai Konsultan maupun Kontraktor.\",\"t42\":\"Peserta memahami penerapan semua yang sudah dikonsep melalui pengamatan hingga mengetahui secara terperinci teknik pelaksanaan di lapangan.\",\"t43\":\"Selesainya studi ditandai dengan karya project design dari konsep ide hingga portofolio realistis — bukan sekadar nilai akademis.\",\"t44\":\"Konsultasi design, bantuan pelaksanaan proyek, hingga bermitra dengan kontraktor dalam pencapaian bisnis dan karir.\",\"t45\":\"Arsitektur Interior <em>SMU/SMK/SLTA</em>\",\"t46\":\"Program khusus pelajar untuk mempersiapkan portofolio masuk perguruan tinggi dalam/luar negeri dan meraih beasiswa perkuliahan di bidang desain.\",\"t47\":\"Pengarahan tujuan dalam mewujudkan harapan yang kuat sebelum menjadikan profesi di dunia design interior.\",\"t48\":\"Teknik menggambar sistem manual: gambar konsep, ilustrasi ide bentuk ke fungsi, dari sketsa hingga gambar kerja mendetail.\",\"t49\":\"Transformasi bentuk dalam membentuk gubahan ruang secara kreatif — konsep, fungsi, komposisi, sirkulasi.\",\"t50\":\"Dimensi dua dan tiga dalam fungsi tatanan ilmu menata ruang: Nirmana datar, nirmana ruang, warna dan pencahayaan.\",\"t51\":\"Ilmu psikologi tentang manusia terhadap sebuah karya yang memberikan sesuatu yang berbeda dari karya setiap designer.\",\"t52\":\"Menggali dan mengembangkan potensi yang mendukung ilmu design melalui indikator pembelajaran yang tepat.\",\"t53\":\"Teknik seni melukis dalam warna dan gambar 2D yang memberikan nuansa nilai lebih dalam sentuhan komunikasi visual.\",\"t54\":\"Produk daur ulang (recycle &amp; upcycle) yang menjadi trend topik di era globalisasi pada industri kreatif design.\",\"t55\":\"Ilmu dasar memahami manusia melalui Sikap, Perilaku, dan Cara Berpikir yang mempengaruhi lahirnya sebuah konsep karya.\",\"t56\":\"Teknik mendisain digital memakai AutoCAD dan SketchUp beserta rendering melalui aplikasi Enscape.\",\"t57\":\"Target hasil setelah <em>menyelesaikan program</em>\",\"t58\":\"Profesi Designer Mandiri\",\"t59\":\"Menjadi Designer dan Kontraktor Interior secara mandiri sekelas pendidikan formal, dengan mengerti teknis membuat konsep design dari dasar hingga selesai proyek.\",\"t60\":\"Bisnis Interior Design\",\"t61\":\"Membuka bisnis interior design sekelas Konsultan Design dan Kontraktor Pelaksana pengadaan secara benar, dalam proses tahapan persiapan yang profesional.\",\"t62\":\"Strategi Kompetitif\",\"t63\":\"Strategi yang kuat dan tepat untuk memenangkan persaingan — dipastikan melalui Program Pendampingan bergaransi setelah selesai pembelajaran.\",\"t64\":\"Portofolio Profesional\",\"t65\":\"Karya project design dari konsep ide hingga portofolio realistis — bukan sekadar nilai akademis. Siap ditampilkan ke klien dan pasar global.\",\"t66\":\"Bersaing di Pasar Global\",\"t67\":\"Skill yang bersaing antar designer — fokus pada praktisi design dan konstruksi bisnis. Siap berhadapan dengan persaingan global.\",\"t68\":\"Portofolio Beasiswa (SMU/SMK)\",\"t69\":\"Portofolio produk design untuk memperkuat pengajuan di perguruan tinggi terkemuka luar negeri maupun meraih program beasiswa global.\",\"t70\":\"Belajar fleksibel, <em>sesuai waktumu</em>\",\"t71\":\"Hari Belajar\",\"t72\":\"Seminggu <strong>2–3 kali pertemuan</strong><br><strong>Senin – Sabtu</strong><br>Fleksibel sesuai kesepakatan kelas\",\"t73\":\"Jam Belajar\",\"t74\":\"<strong>Sesi 1:</strong> Pukul 15.00 – 16.30 WIB<br><strong>Sesi 2:</strong> Pukul 18.00 – 19.30 WIB\",\"t75\":\"Mode Pembelajaran\",\"t76\":\"Tersedia <strong>Online dan Offline</strong>. Pilih yang paling nyaman untukmu — atau kombinasikan keduanya.\",\"t77\":\"Ekstrakulikuler: Clinic Arsitektur &amp; Design\",\"t78\":\"Kegiatan terpadu peserta belajar: diskusi ilmiah antar peserta serta konsultasi design tapak dan ruang kepada masyarakat melalui <strong>pameran design</strong> dan <strong>hari konsultasi design</strong>.\",\"t79\":\"Kata mereka yang <em>telah berhasil</em>\",\"t80\":\"Studi literatur, studi banding, seminar, kunjungan proyek design, hingga praktek kerja langsung bersama mentor.\",\"t81\":\"Ahmad Fauzi\",\"t82\":\"Alumni Profesional Eksklusif\",\"t83\":\"Saya mulai dari nol, tidak punya background desain sama sekali. Setelah ikut program BODHI, dalam 3 bulan saya sudah bisa handle project pertama saya.\",\"t84\":\"Siti Rahayu\",\"t85\":\"Alumni Arsitektur Interior SMU/SMK\",\"t86\":\"Berkat portofolio yang saya buat di BODHI, saya berhasil diterima di universitas desain di Belanda dengan beasiswa penuh. Program ini benar-benar mengubah hidup saya!\",\"t87\":\"Rizky Pratama\",\"t88\":\"Alumni Profesional Eksklusif\",\"t89\":\"Mentor di BODHI tidak hanya mengajar teknis, tapi juga cara berbisnis dan berkomunikasi dengan klien. Sekarang saya punya studio desain sendiri di Medan.\",\"t90\":\"Dewi Lestari\",\"t91\":\"Alumni Profesional Eksklusif\",\"t92\":\"Metode belajarnya sangat praktis dan mudah dipahami. Saya yang tadinya tidak kenal AutoCAD sama sekali, sekarang sudah lancar 2D dan 3D.\",\"t93\":\"Budi Santoso\",\"t94\":\"Alumni Arsitektur Interior SMU/SMK\",\"t95\":\"Pak Jamry mengajar dengan sabar dan metodenya sangat sistematis. Dari gambar manual sampai render 3D, semua diajarkan dengan jelas.\",\"t96\":\"Putri Handayani\",\"t97\":\"Alumni Profesional Eksklusif\",\"t98\":\"Program pendampingan setelah lulus sangat membantu. Saya tidak merasa sendirian saat mengerjakan proyek pertama karena bisa konsultasi langsung.\",\"t99\":\"Mulai perjalananmu jadi <em>designer profesional</em>\",\"t100\":\"Hubungi kami langsung via WhatsApp. Tim dan mentor BODHI siap mendiskusikan program yang paling sesuai dengan tujuan dan latar belakangmu.\",\"t101\":\"Konsultasi Gratis\",\"t102\":\"Isi data di bawah ini, tim kami akan segera menghubungimu.\",\"t103\":\"Dengan mengirim, kamu menyetujui <a href=\\\"javascript:void(0)\\\">Syarat &amp; Ketentuan</a> dan <a href=\\\"javascript:void(0)\\\">Kebijakan Privasi</a> kami.\",\"t104\":\"Ada yang ingin <em>ditanyakan?</em>\",\"t105\":\"Tidak menemukan jawaban yang dicari? Hubungi langsung via WhatsApp dan tim kami siap membantu.\",\"t106\":\"Sama sekali tidak perlu. Kurikulum dirancang mulai dari nol dan mudah dipahami di segala usia. Yang terpenting adalah kemauan belajar dan semangat untuk berkembang.\",\"t107\":\"Program Profesional Eksklusif terdiri dari 50 pertemuan intensif. Dengan jadwal 2-3x per minggu, program bisa diselesaikan dalam beberapa bulan dengan hasil yang komprehensif.\",\"t108\":\"Program Profesional Eksklusif untuk semua kalangan yang ingin berkarir atau membuka bisnis sebagai designer/kontraktor. Program SMU/SMK khusus pelajar yang mempersiapkan portofolio beasiswa luar negeri.\",\"t109\":\"Ya! Program Pendampingan Proyek Design tersedia setelah peserta lulus — konsultasi design, bantuan pelaksanaan proyek, dan kemitraan kontraktor. Bergaransi.\",\"t110\":\"AutoCAD (gambar 2D), SketchUp + 3ds Max (modeling 3D), dan Enscape (rendering realistis). Semua software yang dipakai di industri desain interior profesional.\",\"t111\":\"Isi form konsultasi di halaman ini, dan tim kami akan menghubungi kamu via WhatsApp untuk membahas detail program, jadwal, dan pilihan pembayaran. Konsultasi pertama gratis!\",\"t112\":\"Ya, program tersedia Online maupun Offline. Bisa memilih sesuai kebutuhan dan kenyamananmu, bahkan kombinasi keduanya.\",\"t113\":\"Wadah pendidikan desain interior profesional di Medan. Mencetak designer dan kontraktor interior sejak 2011.\",\"t114\":\"Program\",\"t115\":\"Tentang\",\"t116\":\"Kontak\",\"t117\":\"© 2011–2026 BODHI Creative + Design. Jl. Pelita I No.74D, Medan, Sumatera Utara.\"}","bodhi_settings":"{\"wa\":\"6281234567890\",\"rating\":\"5\",\"brand\":\"BODHI | Creative + Design\",\"trust\":\"Jamri\",\"trustLbl\":\"Dipercaya ratusan alumni\",\"statsYear\":\"2011\",\"statsYearLbl\":\"Tahun berdiri BODHI Creative + Design\",\"stat1n\":\"100+\",\"stat1l\":\"Alumni berkarir\",\"stat2n\":\"50\",\"stat2l\":\"Pertemuan intensif\",\"stat3n\":\"2\",\"stat3l\":\"Program unggulan\",\"stat4n\":\"∞\",\"stat4l\":\"Pendampingan pasca lulus\",\"brandSize1\":\"19\",\"brandSize2\":\"10\"}","bodhi_career":"[{\"yr\":\"1999\",\"txt\":\"Lulus Arsitektur IST TD. Pardede — mulai berkarir sebagai Konsultan & Kontraktor Building\"},{\"yr\":\"2011\",\"txt\":\"Mendirikan BODHI Creative + Design sebagai wadah pendidikan desain informal profesional\"},{\"yr\":\"2014\",\"txt\":\"Delegate Asia Pacific Space Designers Alliance (APSDA) — Solo, Yogyakarta\"},{\"yr\":\"2014–16\",\"txt\":\"Koordinator PSDM Himpunan Designer Interior Indonesia (HDII) Sumatera Utara\"},{\"yr\":\"2021–22\",\"txt\":\"Presiden Lions Club Medan Premier, Distrik 307A2\"},{\"yr\":\"2023\",\"txt\":\"Alumni Faculty Development Institute — Peninsula Jakarta & Regional Lions Leadership Institute — Santika Medan\"},{\"yr\":\"2025\",\"txt\":\"Cambridge\"}]"};
