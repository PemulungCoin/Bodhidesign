<script>
/* =========================================================
   SETTINGS — editable via admin panel
   ========================================================= */
var DEF_SETTINGS = {
  wa:'6281234567890', rating:'4.9', brand:'BODHI | CREATIVE + DESIGN',
  trust:'Ahmad, Siti, Rizky, Dewi', trustLbl:'Dipercaya ratusan alumni',
  statsYear:'2011', statsYearLbl:'Tahun berdiri BODHI Creative + Design',
  stat1n:'100+', stat1l:'Alumni berkarir',
  stat2n:'50',   stat2l:'Pertemuan intensif',
  stat3n:'2',    stat3l:'Program unggulan',
  stat4n:'∞',    stat4l:'Pendampingan pasca lulus',
  brandSize1:'16', brandSize2:'11'
};
var SETTINGS = {};
try { SETTINGS = JSON.parse(localStorage.getItem('bodhi_settings') || '{}'); } catch(e){}
SETTINGS = Object.assign({}, DEF_SETTINGS, SETTINGS);

function applySettings() {
  // Rating
  var rEl = document.getElementById('hero-rating');
  if (rEl) rEl.textContent = SETTINGS.rating || '4.9';
  // Trust dots
  renderTrustDots();
  // Trust label
  var tl = document.getElementById('trust-label');
  if (tl) tl.textContent = SETTINGS.trustLbl || 'Dipercaya ratusan alumni';
  // Brand name (nav + footer)
  applyBrandName(SETTINGS.brand || 'BODHI | CREATIVE + DESIGN');
  // Stats card
  var ids = {
    'stat-year': SETTINGS.statsYear||'2011',
    'stat-year-lbl': SETTINGS.statsYearLbl||'Tahun berdiri BODHI Creative + Design',
    'stat1-num': SETTINGS.stat1n||'100+', 'stat1-lbl': SETTINGS.stat1l||'Alumni berkarir',
    'stat2-num': SETTINGS.stat2n||'50',   'stat2-lbl': SETTINGS.stat2l||'Pertemuan intensif',
    'stat3-num': SETTINGS.stat3n||'2',    'stat3-lbl': SETTINGS.stat3l||'Program unggulan',
    'stat4-num': SETTINGS.stat4n||'∞',   'stat4-lbl': SETTINGS.stat4l||'Pendampingan pasca lulus',
  };
  Object.keys(ids).forEach(function(id) {
    var el = document.getElementById(id); if (el) el.textContent = ids[id];
  });
}

function applyBrandName(val, size1, size2) {
  size1 = size1 || SETTINGS.brandSize1 || '16';
  size2 = size2 || SETTINGS.brandSize2 || '11';
  // Split at | for line break; + applies accent color within each line
  var lines = val.split('|');
  var line1raw = (lines[0] || val).trim();
  var line2raw = lines.length >= 2 ? lines[1].trim() : '';

  function colorPlus(str) {
    // Replace " + " or "+" with accent-colored version
    return str.replace(/\+/g, '<em style="color:var(--acc);font-style:normal">+</em>');
  }

  var html = '<span class="bn-l1" style="font-size:' + size1 + 'px;display:block;line-height:1.1">' + colorPlus(line1raw) + '</span>';
  if (line2raw) {
    html += '<span class="bn-l2" style="font-size:' + size2 + 'px;display:block;line-height:1.2">' + colorPlus(line2raw) + '</span>';
  }
  var nb = document.getElementById('nav-brand');
  if (nb) nb.innerHTML = html;
  var fb = document.getElementById('flogo-nm');
  if (fb) fb.innerHTML = html;
}

function renderTrustDots() {
  var names = (SETTINGS.trust || 'Ahmad,Siti,Rizky,Dewi').split(',').map(function(n){ return n.trim(); }).filter(Boolean).slice(0,4);
  var container = document.getElementById('trust-dots');
  if (!container) return;
  container.innerHTML = '';
  names.forEach(function(name, i) {
    var d = document.createElement('div');
    d.className = 'trust-dot';
    d.title = name;
    var initial = name.charAt(0).toUpperCase();
    // Check for stored photo
    var imgData = localStorage.getItem('bodhi_img_trust_' + i);
    if (imgData) {
      d.innerHTML = '<img src="' + imgData + '" class="show" alt="' + name + '">';
    } else {
      d.textContent = initial;
    }
    container.appendChild(d);
  });
}

function showSettings() {
  document.getElementById('s-wa').value = SETTINGS.wa || '';
  document.getElementById('s-rating').value = SETTINGS.rating || '4.9';
  document.getElementById('s-brand').value = SETTINGS.brand || 'BODHI | CREATIVE + DESIGN';
  document.getElementById('s-trust').value = SETTINGS.trust || '';
  document.getElementById('s-trust-lbl').value = SETTINGS.trustLbl || '';
  document.getElementById('s-year').value = SETTINGS.statsYear || '2011';
  document.getElementById('s-year-lbl').value = SETTINGS.statsYearLbl || 'Tahun berdiri BODHI Creative + Design';
  document.getElementById('s-stat1n').value = SETTINGS.stat1n || '100+';
  document.getElementById('s-stat1l').value = SETTINGS.stat1l || 'Alumni berkarir';
  document.getElementById('s-stat2n').value = SETTINGS.stat2n || '50';
  document.getElementById('s-stat2l').value = SETTINGS.stat2l || 'Pertemuan intensif';
  document.getElementById('s-stat3n').value = SETTINGS.stat3n || '2';
  document.getElementById('s-stat3l').value = SETTINGS.stat3l || 'Program unggulan';
  document.getElementById('s-stat4n').value = SETTINGS.stat4n || '∞';
  document.getElementById('s-stat4l').value = SETTINGS.stat4l || 'Pendampingan pasca lulus';
  // Font size sliders
  var sz1 = SETTINGS.brandSize1 || '16';
  var sz2 = SETTINGS.brandSize2 || '11';
  var sl1 = document.getElementById('s-size1');
  var sl2 = document.getElementById('s-size2');
  if (sl1) { sl1.value = sz1; document.getElementById('s-size1-val').textContent = sz1 + 'px'; }
  if (sl2) { sl2.value = sz2; document.getElementById('s-size2-val').textContent = sz2 + 'px'; }
  previewBrand();
  openModal('modal-settings');
}

function previewBrand() {
  var val  = (document.getElementById('s-brand') || {}).value || SETTINGS.brand || 'BODHI | CREATIVE + DESIGN';
  var sz1  = document.getElementById('s-size1') ? document.getElementById('s-size1').value : (SETTINGS.brandSize1||'16');
  var sz2  = document.getElementById('s-size2') ? document.getElementById('s-size2').value : (SETTINGS.brandSize2||'11');
  var prev = document.getElementById('brand-preview');
  if (!prev) return;
  var lines = val.split('|');
  var l1 = (lines[0]||val).trim();
  var l2 = lines.length >= 2 ? lines[1].trim() : '';
  function cp(s){ return s.replace(/\+/g,'<span style="color:var(--acc)">+</span>'); }
  var html = '<span style="font-size:' + sz1 + 'px;display:block;line-height:1.1;letter-spacing:.5px">' + cp(l1) + '</span>';
  if (l2) html += '<span style="font-size:' + sz2 + 'px;display:block;line-height:1.2;letter-spacing:.5px">' + cp(l2) + '</span>';
  prev.innerHTML = html;
}

function saveSettings() {
  SETTINGS.wa        = document.getElementById('s-wa').value.trim()       || SETTINGS.wa;
  SETTINGS.rating    = document.getElementById('s-rating').value.trim()    || SETTINGS.rating;
  SETTINGS.brand     = document.getElementById('s-brand').value.trim()     || SETTINGS.brand;
  SETTINGS.trust     = document.getElementById('s-trust').value.trim()     || SETTINGS.trust;
  SETTINGS.trustLbl  = document.getElementById('s-trust-lbl').value.trim() || SETTINGS.trustLbl;
  // Stats
  var sy = document.getElementById('s-year').value.trim();    if(sy) SETTINGS.statsYear    = sy;
  var sl = document.getElementById('s-year-lbl').value.trim();if(sl) SETTINGS.statsYearLbl = sl;
  var s1n= document.getElementById('s-stat1n').value.trim();  if(s1n) SETTINGS.stat1n = s1n;
  var s1l= document.getElementById('s-stat1l').value.trim();  if(s1l) SETTINGS.stat1l = s1l;
  var s2n= document.getElementById('s-stat2n').value.trim();  if(s2n) SETTINGS.stat2n = s2n;
  var s2l= document.getElementById('s-stat2l').value.trim();  if(s2l) SETTINGS.stat2l = s2l;
  var s3n= document.getElementById('s-stat3n').value.trim();  if(s3n) SETTINGS.stat3n = s3n;
  var s3l= document.getElementById('s-stat3l').value.trim();  if(s3l) SETTINGS.stat3l = s3l;
  var s4n= document.getElementById('s-stat4n').value.trim();  if(s4n) SETTINGS.stat4n = s4n;
  var s4l= document.getElementById('s-stat4l').value.trim();  if(s4l) SETTINGS.stat4l = s4l;
  // Font sizes
  var fs1 = document.getElementById('s-size1'); if(fs1) SETTINGS.brandSize1 = fs1.value;
  var fs2 = document.getElementById('s-size2'); if(fs2) SETTINGS.brandSize2 = fs2.value;
  try { localStorage.setItem('bodhi_settings', JSON.stringify(SETTINGS)); } catch(e){}
  applySettings();
  closeModal('modal-settings');
  showToast('✅ Pengaturan berhasil disimpan!');
}

function changePass() {
  var oldVal  = document.getElementById('s-pass-old').value;
  var newVal  = document.getElementById('s-pass-new').value;
  var confirm = document.getElementById('s-pass-confirm').value;
  var msg     = document.getElementById('s-pass-msg');
  if (!oldVal || !newVal || !confirm) {
    msg.innerHTML = '<span style="color:#c03030">⚠️ Isi semua kolom password.</span>'; return;
  }
  if (oldVal !== PASS) {
    msg.innerHTML = '<span style="color:#c03030">❌ Password lama salah.</span>'; return;
  }
  if (newVal.length < 6) {
    msg.innerHTML = '<span style="color:#c03030">⚠️ Password baru minimal 6 karakter.</span>'; return;
  }
  if (newVal !== confirm) {
    msg.innerHTML = '<span style="color:#c03030">❌ Konfirmasi password tidak cocok.</span>'; return;
  }
  PASS = newVal;
  try { localStorage.setItem('bodhi_pass', PASS); } catch(e){}
  document.getElementById('s-pass-old').value = '';
  document.getElementById('s-pass-new').value = '';
  document.getElementById('s-pass-confirm').value = '';
  msg.innerHTML = '<span style="color:var(--green)">✅ Password berhasil diganti!</span>';
  setTimeout(function(){ msg.innerHTML=''; }, 3000);
}

