function resizeAndSave(file, storageKey, callback) {
  var reader = new FileReader();
  reader.onload = function(e) {
    var img = new Image();
    img.onload = function() {
      var canvas = document.createElement('canvas');
      var MAX=700, w=img.width, h=img.height;
      if (w>MAX||h>MAX) { if(w>=h){h=Math.round(h*MAX/w);w=MAX;}else{w=Math.round(w*MAX/h);h=MAX;} }
      canvas.width=w; canvas.height=h;
      canvas.getContext('2d').drawImage(img,0,0,w,h);
      var data = canvas.toDataURL('image/jpeg',.78);
      try { localStorage.setItem(storageKey, data); } catch(er){}
      callback(data);
    };
    img.src = e.target.result;
  };
  reader.readAsDataURL(file);
}

function handleImgFile(event) {
  var file = event.target.files[0];
  if (!file || !_imgTarget) return;
  if (!file.type.startsWith('image/')) { alert('Pilih file gambar (JPG, PNG, dll.)'); return; }
  resizeAndSave(file, 'bodhi_img_'+_imgTarget.key, function(data) {
    if (_imgTarget.mode === 'img') {
      // src mode — show <img> element, hide placeholder
      var imgEl = document.getElementById(_imgTarget.elId);
      if (imgEl) { imgEl.src = data; imgEl.style.display = 'block'; }
      var ph = document.getElementById('about-img-placeholder');
      if (ph) ph.style.display = 'none';
    } else {
      applyBgImg(_imgTarget.elId, data);
    }
  });
}

function handleLogoFile(event) {
  var file = event.target.files[0];
  if (!file || !file.type.startsWith('image/')) return;
  resizeAndSave(file, 'bodhi_img_logo', function(data) {
    // Apply to nav logo
    var navImg = document.getElementById('nav-logo-img');
    navImg.src = data; navImg.classList.add('show');
    document.getElementById('nav-logo-def').style.display = 'none';
    // Apply to footer logo
    var fImg = document.getElementById('flogo-img');
    fImg.src = data; fImg.classList.add('show');
    document.getElementById('flogo-def').style.display = 'none';
  });
}

function applyBgImg(elId, data) {
  var el = document.getElementById(elId);
  if (!el) return;
  el.style.backgroundImage = 'url('+data+')';
  el.style.backgroundSize = 'cover';
  el.style.backgroundPosition = 'center';
  el.style.display = 'block';
  // Hide placeholder icon when hero image is loaded
  if (elId === 'hero-card-img') {
    var icon = document.querySelector('.hero-card-icon');
    if (icon) icon.style.display = 'none';
  }
}

