  if (h1) { h1.style.fontFamily=fhf.css; h1.style.fontSize=sz('sz-h1',52); h1.style.fontWeight='700'; }
  if (h2) { h2.style.fontFamily=fhf.css; h2.style.fontSize=sz('sz-h2',36); h2.style.fontWeight='600'; }
  if (h3) { h3.style.fontFamily=fhf.css; h3.style.fontSize=sz('sz-h3',26); h3.style.fontWeight='600'; }
  if (bd) { bd.style.fontFamily=fbf.css; bd.style.fontSize=sz('sz-p',15); }
  if (bt) { bt.style.fontFamily=fbf.css; bt.style.fontSize=sz('sz-btn',14); bt.style.fontWeight='700'; }
  if (sm) { sm.style.fontFamily=fbf.css; sm.style.fontSize=sz('sz-small',12); }
}

function showTypo() {
  // Build heading font grid
  var hg = document.getElementById('typo-head-grid'); hg.innerHTML = '';
  var selH = TYPO.fontHead || DEF_TYPO.fontHead;
  FONTS_HEAD.forEach(function(f){ hg.appendChild(buildFontCard(f, 'head', f.name===selH)); });

  // Build body font grid
  var bg = document.getElementById('typo-body-grid'); bg.innerHTML = '';
  var selB = TYPO.fontBody || DEF_TYPO.fontBody;
  FONTS_BODY.forEach(function(f){ bg.appendChild(buildFontCard(f, 'body', f.name===selB)); });

  // Build heading size sliders
  var hs = document.getElementById('typo-head-sizes'); hs.innerHTML = '';
  HEAD_SIZES.forEach(function(s){ hs.appendChild(buildSizeRow(s)); });

  // Build body size sliders
  var bs = document.getElementById('typo-body-sizes'); bs.innerHTML = '';
  BODY_SIZES.forEach(function(s){ bs.appendChild(buildSizeRow(s)); });

  updateTypoPreview();
  openModal('modal-typo');
}

function saveTypo() {
  try { localStorage.setItem('bodhi_typo', JSON.stringify(TYPO)); } catch(e){}
  applyTypo();
  closeModal('modal-typo');
  showToast('✅ Tipografi berhasil disimpan!');
}

/* =========================================================
   FIX 5: CAREER TIMELINE — editable via admin
   ========================================================= */
var DEF_CAREER = [
  {yr:'1999', txt:'Lulus Arsitektur IST TD. Pardede — mulai berkarir sebagai Konsultan & Kontraktor Building'},
  {yr:'2011', txt:'Mendirikan BODHI Creative + Design sebagai wadah pendidikan desain informal profesional'},
  {yr:'2014', txt:'Delegate Asia Pacific Space Designers Alliance (APSDA) — Solo, Yogyakarta'},
  {yr:'2014–16', txt:'Koordinator PSDM Himpunan Designer Interior Indonesia (HDII) Sumatera Utara'},
  {yr:'2021–22', txt:'Presiden Lions Club Medan Premier, Distrik 307A2'},
  {yr:'2023',   txt:'Alumni Faculty Development Institute — Peninsula Jakarta & Regional Lions Leadership Institute — Santika Medan'}
];
var CAREER = [];
try { CAREER = JSON.parse(localStorage.getItem('bodhi_career') || 'null') || DEF_CAREER.slice(); } catch(e) { CAREER = DEF_CAREER.slice(); }

function renderCareerTimeline() {
  var tl = document.getElementById('career-timeline');
  if (!tl) return;
  tl.innerHTML = CAREER.map(function(item) {
    return '<div class="fd-item"><span class="fd-yr">' + item.yr + '</span><span class="fd-txt">' + item.txt + '</span></div>';
  }).join('');
}

function showCareerModal() {
  var list = document.getElementById('career-list');
  list.innerHTML = '';
  CAREER.forEach(function(item, i) {
    var row = document.createElement('div');
    row.style.cssText = 'display:grid;grid-template-columns:90px 1fr auto;gap:8px;align-items:start;background:var(--bgwarm);border:1px solid var(--bdr);border-radius:10px;padding:12px';
    row.innerHTML = '<input type="text" value="' + item.yr + '" placeholder="Tahun" class="minput" style="font-size:13px;padding:8px 10px" data-idx="' + i + '" data-field="yr">'
      + '<input type="text" value="' + item.txt.replace(/"/g,'&quot;') + '" placeholder="Deskripsi karier..." class="minput" style="font-size:13px;padding:8px 10px" data-idx="' + i + '" data-field="txt">'
      + '<button onclick="removeCareerItem(' + i + ')" style="background:#fdeaea;color:#c03030;border:1px solid #f0c0c0;border-radius:6px;padding:6px 10px;cursor:pointer;font-size:13px;flex-shrink:0">🗑</button>';
    row.querySelectorAll('input').forEach(function(inp) {
      inp.addEventListener('input', function() {
        CAREER[parseInt(inp.dataset.idx)][inp.dataset.field] = inp.value;
      });
    });
    list.appendChild(row);
  });
  openModal('modal-career');
}

function addCareerItem() {
  CAREER.push({yr: '', txt: ''});
  showCareerModal();
}

function removeCareerItem(i) {
  CAREER.splice(i, 1);
  showCareerModal();
}

function saveCareer() {
  try { localStorage.setItem('bodhi_career', JSON.stringify(CAREER)); } catch(e) {}
  renderCareerTimeline();
  closeModal('modal-career');
  showToast('✅ Perjalanan Karier disimpan!');
}

/* =========================================================
   FIX 6: SECTION BACKGROUNDS — per-section image + blur + position
   ========================================================= */
var SEC_BG_DEFS = [
  {id:'about',        label:'Tentang BODHI',    secId:'about'},
  {id:'founder',      label:'Pengajar',          secId:'founder'},
  {id:'programs',     label:'Program Studi',     secId:'programs'},
  {id:'schedule',     label:'Jadwal Belajar',    secId:'schedule'},
  {id:'testimonials', label:'Testimoni Alumni',  secId:'testimonials'},
];
var SEC_BGS = {};
try { SEC_BGS = JSON.parse(localStorage.getItem('bodhi_secbgs') || '{}'); } catch(e) {}

function applySectionBgs() {
  SEC_BG_DEFS.forEach(function(def) {
    var cfg = SEC_BGS[def.id];
    var sec = document.getElementById(def.secId);
    if (!sec) return;
    var el = document.getElementById('secbg-el-' + def.id);
    if (!el) {
      el = document.createElement('div');
      el.id = 'secbg-el-' + def.id;
      el.style.cssText = 'position:absolute;inset:0;z-index:0;pointer-events:none';
      if (getComputedStyle(sec).position === 'static') sec.style.position = 'relative';
      sec.insertBefore(el, sec.firstChild);
    }
    if (cfg && cfg.img) {
      var blur  = cfg.blur  || 0;
      var opacity = (cfg.opacity !== undefined ? cfg.opacity : 15) / 100;
      var posX  = cfg.posX  || 'center';
      var posY  = cfg.posY  || 'center';
      var size  = cfg.size  || 'cover';
      el.style.backgroundImage    = 'url(' + cfg.img + ')';
      el.style.backgroundSize     = size;
      el.style.backgroundPosition = posX + ' ' + posY;
      el.style.filter             = blur > 0 ? 'blur(' + blur + 'px)' : '';
      el.style.opacity            = opacity;
      el.style.display            = 'block';
    } else {
      el.style.display = 'none';
    }
  });
}

function showSecBg() {
  var list = document.getElementById('secbg-list');
  list.innerHTML = '';
  SEC_BG_DEFS.forEach(function(def) {
    var cfg = SEC_BGS[def.id] || {};
    var card = document.createElement('div');
    card.style.cssText = 'border:1px solid var(--bdr);border-radius:14px;overflow:hidden';
    var imgThumb = cfg.img ? '<img src="' + cfg.img + '" style="width:60px;height:60px;object-fit:cover;border-radius:8px;flex-shrink:0">' : '<div style="width:60px;height:60px;background:var(--bg2);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0">🖼</div>';
    card.innerHTML = '<div style="padding:14px 16px;display:flex;align-items:center;gap:14px">'
      + imgThumb
      + '<div style="flex:1"><div style="font-weight:700;font-size:14px">' + def.label + '</div>'
      + '<div style="font-size:12px;color:var(--muted)">' + (cfg.img ? 'Gambar aktif' : 'Belum ada gambar') + '</div></div>'
      + '<div style="display:flex;gap:6px">'
      + '<button onclick="triggerSecBgUpload(\'' + def.id + '\')" style="background:var(--acc);color:#fff;border:none;padding:7px 14px;border-radius:8px;cursor:pointer;font-size:12px;font-weight:700;font-family:inherit">📷 Upload</button>'
      + (cfg.img ? '<button onclick="removeSecBg(\'' + def.id + '\')" style="background:#fdeaea;color:#c03030;border:1px solid #f0c0c0;padding:7px 10px;border-radius:8px;cursor:pointer;font-size:12px;font-family:inherit">🗑</button>' : '')
      + '</div></div>'
      + (cfg.img ? '<div style="padding:0 16px 14px;display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px">'
        + '<div><div style="font-size:11px;font-weight:600;color:var(--muted);margin-bottom:5px">Opasitas ' + (cfg.opacity||15) + '%</div><input type="range" min="5" max="100" value="' + (cfg.opacity||15) + '" style="width:100%;accent-color:var(--acc)" oninput="updateSecBgProp(\'' + def.id + '\',\'opacity\',this.value);this.previousElementSibling.textContent=\'Opasitas \'+this.value+\'%\'"></div>'
        + '<div><div style="font-size:11px;font-weight:600;color:var(--muted);margin-bottom:5px">Blur ' + (cfg.blur||0) + 'px</div><input type="range" min="0" max="20" value="' + (cfg.blur||0) + '" style="width:100%;accent-color:var(--acc)" oninput="updateSecBgProp(\'' + def.id + '\',\'blur\',this.value);this.previousElementSibling.textContent=\'Blur \'+this.value+\'px\'"></div>'
        + '<div><div style="font-size:11px;font-weight:600;color:var(--muted);margin-bottom:5px">Ukuran</div><select onchange="updateSecBgProp(\'' + def.id + '\',\'size\',this.value)" style="width:100%;padding:5px 8px;border:1px solid var(--bdr);border-radius:6px;font-size:12px;font-family:inherit">'
        + ['cover','contain','auto'].map(function(v){ return '<option value="' + v + '"' + (cfg.size===v?' selected':'') + '>' + v + '</option>'; }).join('')
        + '</select></div>'
        + '</div>' : '');
    list.appendChild(card);
  });
  openModal('modal-secbg');
}

var _secBgTarget = null;
function triggerSecBgUpload(secId) {
  _secBgTarget = secId;
  var inp = document.getElementById('secbg-file-input');
  if (!inp) {
    inp = document.createElement('input');
    inp.type = 'file'; inp.accept = 'image/*'; inp.id = 'secbg-file-input';
    inp.style.display = 'none';
    inp.addEventListener('change', function(e) {
      var file = e.target.files[0];
      if (!file || !_secBgTarget) return;
      resizeAndSave(file, 'bodhi_secbg_' + _secBgTarget, function(data) {
        if (!SEC_BGS[_secBgTarget]) SEC_BGS[_secBgTarget] = {};
        SEC_BGS[_secBgTarget].img = data;
        saveSectionBgs();
        showSecBg();
        applySectionBgs();
      });
    });
    document.body.appendChild(inp);
  }
  inp.value = ''; inp.click();
}

function removeSecBg(secId) {
  if (SEC_BGS[secId]) { delete SEC_BGS[secId].img; }
  saveSectionBgs();
  applySectionBgs();
  showSecBg();
}

function updateSecBgProp(secId, prop, val) {
  if (!SEC_BGS[secId]) SEC_BGS[secId] = {};
  SEC_BGS[secId][prop] = isNaN(val) ? val : Number(val);
  saveSectionBgs();
  applySectionBgs();
}

function saveSectionBgs() {
  // Don't save raw base64 in SEC_BGS object — it's already in localStorage as bodhi_secbg_*
  // Save only the config (opacity, blur, size) not the image data
  var cfg = {};
  SEC_BG_DEFS.forEach(function(def) {
    if (SEC_BGS[def.id]) {
      cfg[def.id] = {
        opacity: SEC_BGS[def.id].opacity,
        blur:    SEC_BGS[def.id].blur,
        size:    SEC_BGS[def.id].size,
        hasImg:  !!SEC_BGS[def.id].img
      };
    }
  });
  try { localStorage.setItem('bodhi_secbgs_cfg', JSON.stringify(cfg)); } catch(e) {}
}

function loadSectionBgImages() {
  // Load images from localStorage into SEC_BGS
  var cfg = {};
  try { cfg = JSON.parse(localStorage.getItem('bodhi_secbgs_cfg') || '{}'); } catch(e) {}
  SEC_BG_DEFS.forEach(function(def) {
    var img = localStorage.getItem('bodhi_secbg_' + def.id);
    if (img) {
      SEC_BGS[def.id] = Object.assign({}, cfg[def.id] || {}, {img: img});
    }
  });
}

/* =========================================================
   INIT
   ========================================================= */
applySettings();
applyTypo();
renderCareerTimeline();
loadSectionBgImages();
loadStoredImages();
loadTexts();
</script>


